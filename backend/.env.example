# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=student_career_counselor
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false

# ─────────────────────────────────────────────
# JWT / Token Secrets
# ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
UPGRADE_TOKEN_SECRET=change_this_to_another_long_random_secret
UPGRADE_TOKEN_EXPIRY_DAYS=30

# ─────────────────────────────────────────────
# Razorpay
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
PAID_REPORT_AMOUNT=49900

# ─────────────────────────────────────────────
# Email (SMTP)
# For Gmail: use app password, host=smtp.gmail.com, port=587
# For SendGrid: host=smtp.sendgrid.net, port=587, user=apikey
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM_NAME=Akash Universal Solutions
EMAIL_FROM_ADDRESS=adish@akashuniversalsolutions.com

# ─────────────────────────────────────────────
# LLM Provider
# Options: openai | anthropic | gemini | static
# Use "static" to skip LLM and use built-in question bank
# ─────────────────────────────────────────────
LLM_PROVIDER=static
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ─────────────────────────────────────────────
# PDF Storage
# Base URL for serving PDFs (append /pdfs/filename)
# ─────────────────────────────────────────────
PDF_STORAGE_PATH=./storage/pdfs
PDF_BASE_URL=http://localhost:5000/pdfs
